{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun", "node"]
  },
  "include": [
    "browse/src/**/*",
    "browse/test/**/*",
    "scripts/**/*",
    "test/**/*"
  ]
}
